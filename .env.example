# Pick ONE provider. Server-side only — never expose to the browser.

# OpenAI (default; supports vision via gpt-4o-mini)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Supabase — OPTIONAL. Enables cross-browser Share (/share/[shareId]).
# Server-side only; never exposed to the browser. If unset, Share falls back to
# localStorage (same-browser only). Use the SERVICE ROLE key, not the anon key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
